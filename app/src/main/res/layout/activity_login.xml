<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray"
    tools:context=".MainActivity">

    <!-- Clear Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/buspic"
        android:alpha="1.0" />

    <!-- Semi-transparent White Scrim for contrast -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66FFFFFF" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#33000000"
        app:cardBackgroundColor="#B3FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOGIN"
                android:textColor="@color/primaryGreen"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transport Management Portal"
                android:textColor="@color/textSecondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.15" />

            <View
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:background="@color/primaryGreen"
                android:layout_marginTop="16dp"
                android:alpha="0.3"/>

            <!-- Username Field -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:hint="Username"
                android:textColorHint="@color/textSecondary"
                app:hintTextColor="@color/primaryGreen"
                app:boxStrokeColor="@color/primaryGreen"
                app:boxBackgroundMode="outline"
                app:startIconDrawable="@drawable/person_24px"
                app:startIconTint="@color/primaryGreen"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textDark"
                    android:inputType="text"
                    android:textSize="15sp"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password Field -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Password"
                android:textColorHint="@color/textSecondary"
                app:hintTextColor="@color/primaryGreen"
                app:boxStrokeColor="@color/primaryGreen"
                app:boxBackgroundMode="outline"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/textSecondary"
                app:startIconDrawable="@drawable/settings_24px"
                app:startIconTint="@color/primaryGreen"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textDark"
                    android:inputType="textPassword"
                    android:textSize="15sp"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Sign In"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:backgroundTint="@color/primaryGreen"
                android:fontFamily="sans-serif-black"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                app:cornerRadius="12dp"
                app:elevation="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Forgot Password?"
                android:textColor="@color/primaryGreen"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SYSTEM v1.0 • BUSTRACKER PRO"
        android:textColor="@color/textSecondary"
        android:textSize="10sp"
        android:letterSpacing="0.3"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
