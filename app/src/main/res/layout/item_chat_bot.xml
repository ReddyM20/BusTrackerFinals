<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvBotName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:text="BusHelper"
        android:textColor="#999999"
        android:textSize="10sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivBotAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/pill_background"
            android:backgroundTint="@color/primaryGreen"
            android:padding="6dp"
            android:src="@drawable/person_24px"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvMessageBot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="64dp"
            android:background="@drawable/chat_bubble_bot"
            android:padding="12dp"
            android:text="Hello! How can I help you today?"
            android:textColor="@color/chat_text_bot"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Quick Replies Container -->
    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/flexQuickReplies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginTop="8dp"
        app:flexWrap="wrap"
        app:justifyContent="flex_start" />

</LinearLayout>